# Przykładowa konfiguracja. Skopiuj do .env (gitignorowane) i uzupełnij.
# UWAGA: prawdziwe certyfikaty i sekrety NIGDY nie trafiają do repo.

# Środowisko P1: integracja | produkcja
P1_ENV=integracja

# Serwis podpisu XAdES (Java/DSS)
XADES_SIGNER_URL=http://localhost:8080

# Ścieżki do certyfikatów (poza repo, np. w .local/certs)
P1_TLS_CERT_PATH=.local/certs/tls.p12
P1_WSS_CERT_PATH=.local/certs/wss.p12
# Hasła do certyfikatów wstrzykiwane przez środowisko
P1_TLS_CERT_PASSWORD=
P1_WSS_CERT_PASSWORD=
