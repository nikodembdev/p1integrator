# Przykładowa konfiguracja smoke-testu / e2e P1 (scripts/smoke-eskierowanie.ts,
# test/integration/e2e-p1.test.ts). Skopiuj realne wartości do `.local/p1.env`
# (gitignored, ładowany automatycznie) - NIE wypełniaj tego pliku sekretami/danymi konta.
# UWAGA: certyfikaty i hasła NIGDY nie trafiają do repo (.local/ jest w .gitignore).

# Sekret + endpointy
CERT_PASSWORD=
P1_ENDPOINT=https://isus.ezdrowie.gov.pl/services/ObslugaSkierowaniaWS
P1_XADES_URL=http://localhost:8080/api/v1/sign
# P1_CERT_DIR=                       # domyślnie .local/certs/Podmiot_leczniczy_713
# P1_TLS_REJECT_UNAUTHORIZED=false   # tylko gdy serwer P1 nie jest publicznie zaufany

# Dane konta integracyjnego (z przydziału CSIOZ) - patrz .local/INTEGRACJA-DOSTEP.md
P1_LOCAL_ROOT=          # węzeł OID usługodawcy, np. 2.16.840.1.113883.3.4424.2.7.XXXX
P1_PODMIOT_EXT=         # identyfikator biznesowy podmiotu (extension)
P1_NPWZ=               # NPWZ lekarza
# Imię/nazwisko lekarza; dla zdarzeń medycznych musi zgadzać się z CWPM po NPWZ (REG.WER.4059)
P1_DOCTOR_GIVEN=       # domyślnie Adam
P1_DOCTOR_FAMILY=      # domyślnie Leczniczy
P1_REGON14=
P1_REGON9=
P1_NFZ_BRANCH=         # kod oddziału NFZ, np. 06
P1_NFZ_CONTRACT=       # numer umowy NFZ
P1_ORG_UNIT_EXT=       # jednostka org. (root .2.3.2), np. <ksiega>-<res5>
P1_MUS_ROOT=2.16.840.1.113883.3.4424.2.3.3
P1_MUS_EXT=            # krótki kod komórki (res7), np. 001  ← MUŚ w kontekście wywołania

# Pacjent testowy (zarejestrowany w CWUb)
P1_PATIENT_PESEL=
P1_PATIENT_GIVEN=
P1_PATIENT_FAMILY=
P1_PATIENT_BIRTH=      # YYYYMMDD
P1_PATIENT_GENDER=M

# e-recepta (Faza 3 e2e) - opcjonalne; domyślnie wyliczane z P1_LOCAL_ROOT (nasz węzeł OID).
# Numer recepty (id) = <P1_LOCAL_ROOT>.2.1, zbiór wersji (setId) = <P1_LOCAL_ROOT>.2.2 -
# oba MUSZĄ bazować na naszym węźle (REG.WER.376 / REG.WER.3673 sprawdzają zgodność z kontekstem).
P1_RECEPTA_ENDPOINT=https://isus.ezdrowie.gov.pl/services/ObslugaReceptyWS
# P1_RECEPTA_LOCAL_ROOT=        # domyślnie P1_LOCAL_ROOT
# P1_RECEPTA_VERSIONSET_ROOT=   # domyślnie <P1_LOCAL_ROOT>.2.2

# Zdarzenia medyczne (ZM) - REST/FHIR + OAuth2 (inny host i stack niż SOAP wyżej)
P1_ZM_TOKEN_ENDPOINT=https://isus.ezdrowie.gov.pl/token
P1_ZM_FHIR_URL=https://isus.ezdrowie.gov.pl/fhir
