{
  "name": "@p1/transport",
  "version": "0.0.0",
  "description": "Port HttpClient (mTLS) + koperty SOAP + podpis WS-Security",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@p1/core": "workspace:*",
    "fast-xml-parser": "^4.5.1",
    "node-forge": "^1.3.1",
    "xml-crypto": "^6.0.1"
  },
  "devDependencies": {
    "@types/node-forge": "^1.3.11"
  },
  "publishConfig": {
    "access": "public"
  }
}
