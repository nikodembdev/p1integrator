{
  "name": "@p1/medical-events",
  "version": "0.0.0",
  "description": "Moduł zdarzeń medycznych (ZM) - FHIR R4 + OAuth2",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@p1/core": "workspace:*",
    "@xmldom/xmldom": "^0.9.10",
    "node-forge": "^1.4.0",
    "xml-crypto": "^6.1.2"
  },
  "devDependencies": {
    "@types/node-forge": "^1.3.14"
  },
  "publishConfig": {
    "access": "public"
  }
}
