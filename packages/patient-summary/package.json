{
  "name": "@p1/patient-summary",
  "version": "0.0.0",
  "description": "Moduł Patient Summary (Karta Pacjenta) - pobieranie podsumowania pacjenta (REST + OAuth2)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@p1/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
